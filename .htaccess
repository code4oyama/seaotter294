# Repository root fallback for environments where DocumentRoot points to project root
# Routes all non-file/non-directory requests to /public.

DirectoryIndex index.php public/index.php

# Deny direct access to environment files (.env, .env.local, etc.)
<FilesMatch "^\.env(\..*)?$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to environment files
    RewriteRule (^|/)\.env(\..*)?$ - [F,L,NC]

    # Root path to public front controller
    RewriteRule ^$ public/index.php [L]

    # Keep existing files/directories at root accessible if needed
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route all app requests through public front controller
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>
